<script>
// ---------- FIREBASE CONFIG (loaded from external config.js) ----------
if (typeof window.FIREBASE_CONFIG === 'undefined') {
  console.error('ERROR: config.js not loaded. Please create config.js with your Firebase settings.');
  alert('Configuration missing. Please create config.js (see instructions).');
} else {
  firebase.initializeApp(window.FIREBASE_CONFIG);
}
const db = firebase.firestore();

// ---------- GLOBAL DATA ----------
let students = [], teachers = [], currentUser = null;
let adminPassword = 'admin123';
let globalBgImage = '', globalSignatureImage = '';
let globalTeacherBgImage = '', globalTeacherSignatureImage = '';

// ---------- HELPERS ----------
function showLoading(show) { document.getElementById('loadingOverlay').style.display = show ? 'flex' : 'none'; }
function fileToBase64(file, maxKB=60) {
  return new Promise((resolve, reject) => {
    if (!file) { resolve(null); return; }
    if (file.size > maxKB * 1024) reject(`File exceeds ${maxKB} KB`);
    const r = new FileReader();
    r.onload = e => resolve(e.target.result);
    r.onerror = () => reject("Read error");
    r.readAsDataURL(file);
  });
}
function escapeHtml(str) { if(!str) return ''; return str.replace(/[&<>]/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;'}[m])); }
function normalizeDateToYMD(str) {
  if (!str) return '';
  if (/^\d{4}-\d{2}-\d{2}$/.test(str)) return str;
  const parts = str.split('/');
  if (parts.length === 3) return `${parts[2]}-${parts[1].padStart(2,'0')}-${parts[0].padStart(2,'0')}`;
  return str;
}

// ---------- FIREBASE DATA LOADING ----------
async function loadDataFromFirebase() {
  showLoading(true);
  try {
    const [studSnap, teachSnap, configDoc, passDoc] = await Promise.all([
      db.collection('students').get(),
      db.collection('teachers').get(),
      db.collection('config').doc('images').get(),
      db.collection('config').doc('admin').get()
    ]);
    students = studSnap.docs.map(doc => ({ id: doc.id, ...doc.data() }));
    teachers = teachSnap.docs.map(doc => ({ id: doc.id, ...doc.data() }));
    students.forEach(s => s._printSelected = false);
    if (configDoc.exists) {
      const d = configDoc.data();
      globalBgImage = d.globalBgImage || '';
      globalSignatureImage = d.globalSignatureImage || '';
      globalTeacherBgImage = d.globalTeacherBgImage || '';
      globalTeacherSignatureImage = d.globalTeacherSignatureImage || '';
    }
    if (passDoc.exists) adminPassword = passDoc.data().password || 'admin123';
  } catch (e) { console.error(e); alert('Failed to load data'); }
  finally { showLoading(false); }
}

async function saveGlobalImages() { await db.collection('config').doc('images').set({ globalBgImage, globalSignatureImage, globalTeacherBgImage, globalTeacherSignatureImage }).catch(console.error); }
async function saveAdminPassword() { await db.collection('config').doc('admin').set({ password: adminPassword }).catch(console.error); }
async function addStudentToFB(s) { const docRef = await db.collection('students').add(s); s.id = docRef.id; return s; }
async function updateStudentInFB(s) { await db.collection('students').doc(s.id).set(s); }
async function deleteStudentFromFB(id) { await db.collection('students').doc(id).delete(); }
async function addTeacherToFB(t) { const docRef = await db.collection('teachers').add(t); t.id = docRef.id; return t; }
async function updateTeacherInFB(t) { await db.collection('teachers').doc(t.id).set(t); }
async function deleteTeacherFromFB(id) { await db.collection('teachers').doc(id).delete(); }

function getClassOptions() {
  let options = '<option value="">--Select--</option>';
  options += '<option>LKG-A</option><option>LKG-B</option><option>UKG-A</option><option>UKG-B</option>';
  for (let i=1;i<=10;i++) options += `<option>${i}-A</option><option>${i}-B</option>`;
  return options;
}
function getClassFilterOptions() {
  let options = '<option value="">All Classes</option>';
  options += '<option>LKG-A</option><option>LKG-B</option><option>UKG-A</option><option>UKG-B</option>';
  for (let i=1;i<=10;i++) options += `<option>${i}-A</option><option>${i}-B</option>`;
  return options;
}

// --- Student Management (unchanged) ---
let currentStudentId=null, studentSearchTerm='', adminStudentClassFilter='';
function renderStudentList() {
  const c=document.getElementById('studentList'); if(!c) return;
  let f=students.filter(s=>s.name.toLowerCase().includes(studentSearchTerm.toLowerCase())||(s.class&&s.class.toLowerCase().includes(studentSearchTerm.toLowerCase())));
  if(adminStudentClassFilter) f=f.filter(s=>s.class===adminStudentClassFilter);
  if(!f.length){c.innerHTML='<div style="padding:15px;">No students.</div>';return;}
  c.innerHTML=f.map(s=>`<div class="list-item ${currentStudentId===s.id?'selected':''}" data-id="${escapeHtml(s.id)}"><span class="item-name">${escapeHtml(s.name)} (${escapeHtml(s.class||'')})</span><div class="item-actions"><button class="view-btn" data-id="${escapeHtml(s.id)}">👁️ View</button><button class="edit-btn" data-id="${escapeHtml(s.id)}">✏️</button><button class="delete-btn" data-id="${escapeHtml(s.id)}">🗑️</button></div></div>`).join('');
  attachStudentListEvents();
}
function attachStudentListEvents(){
  const container=document.getElementById('studentList'); if(!container) return;
  container.querySelectorAll('.list-item').forEach(el=>{el.removeEventListener('click',studentItemClick);el.addEventListener('click',studentItemClick);});
  container.querySelectorAll('.view-btn').forEach(b=>b.addEventListener('click',e=>{e.stopPropagation();viewStudentInfo(b.dataset.id);}));
  container.querySelectorAll('.edit-btn').forEach(b=>b.addEventListener('click',e=>{e.stopPropagation();openStudentForm(b.dataset.id);}));
  container.querySelectorAll('.delete-btn').forEach(b=>b.addEventListener('click',async e=>{e.stopPropagation();if(!confirm('Delete?'))return;showLoading(true);await deleteStudentFromFB(b.dataset.id);students=students.filter(s=>s.id!==b.dataset.id);if(currentStudentId===b.dataset.id)currentStudentId=students[0]?.id||null;renderStudentList();updateAdminStats();currentStudentId?loadStudentToCard(currentStudentId):clearStudentCard();showLoading(false);}));
}
function studentItemClick(e){if(e.target.classList.contains('edit-btn')||e.target.classList.contains('delete-btn')||e.target.classList.contains('view-btn'))return;currentStudentId=e.currentTarget.dataset.id;loadStudentToCard(currentStudentId);renderStudentList();}
let currentEditId=null;
function openStudentForm(id=null){
  const formDiv=document.getElementById('studentFormDiv'); if(!formDiv) return;
  formDiv.style.display='block';
  if(!id){currentEditId=null;document.getElementById('formTitle').innerText='Add Student';['studentName','studentClass','studentRoll','studentDob','studentFather','studentContact','studentAddress'].forEach(x=>document.getElementById(x).value='');document.getElementById('studentPhotoFile').value='';}
  else{const s=students.find(s=>s.id===id);if(!s)return;currentEditId=id;document.getElementById('formTitle').innerText='Edit Student';document.getElementById('studentName').value=s.name||'';document.getElementById('studentClass').value=s.class||'';document.getElementById('studentRoll').value=s.roll||'';document.getElementById('studentDob').value=s.dob||'';document.getElementById('studentFather').value=s.father||'';document.getElementById('studentContact').value=s.contact||'';document.getElementById('studentAddress').value=s.address||'';}
}
async function saveStudentForm(){
  const name=document.getElementById('studentName').value.trim();if(!name){alert('Name required');return;}
  const data={name,class:document.getElementById('studentClass').value,roll:document.getElementById('studentRoll').value,dob:document.getElementById('studentDob').value,father:document.getElementById('studentFather').value,contact:document.getElementById('studentContact').value,address:document.getElementById('studentAddress').value,mobile:document.getElementById('studentContact').value};
  const file=document.getElementById('studentPhotoFile').files[0];let photo='';if(file){try{photo=await fileToBase64(file,60);}catch(e){alert(e);return;}}
  showLoading(true);
  if(currentEditId===null){const newStudent={...data,photoImage:photo,positions:{}};const added=await addStudentToFB(newStudent);students.push(added);currentStudentId=added.id;}
  else{const idx=students.findIndex(s=>s.id===currentEditId);if(idx!==-1){const updated={...students[idx],...data,photoImage:photo||students[idx].photoImage};await updateStudentInFB(updated);students[idx]=updated;}currentStudentId=currentEditId;}
  renderStudentList();updateAdminStats();loadStudentToCard(currentStudentId);document.getElementById('studentFormDiv').style.display='none';currentEditId=null;showLoading(false);
}
function cancelStudentForm(){document.getElementById('studentFormDiv').style.display='none';currentEditId=null;}
function filterStudentList(){const inp=document.getElementById('studentSearch');if(inp)studentSearchTerm=inp.value;renderStudentList();}
function filterAdminStudentByClass(){adminStudentClassFilter=document.getElementById('adminStudentClassFilter')?.value||'';renderStudentList();}

// --- Student Card ---
let studentLocked=false;
function clearStudentCard(){if(!document.getElementById('studentCard'))return;document.getElementById('showName').innerText='YOUR NAME';['showClass','showRoll','showDob','showFather','showContact','showAddress'].forEach(x=>document.getElementById(x).innerText='');document.getElementById('photoPreview').src='';applyStudentGlobal();}
function loadStudentToCard(id){const s=students.find(s=>s.id===id);if(!s||!document.getElementById('showName'))return;document.getElementById('showName').innerText=s.name||'YOUR NAME';document.getElementById('showClass').innerText=s.class||'';document.getElementById('showRoll').innerText=s.roll||'';document.getElementById('showDob').innerText=s.dob||'';document.getElementById('showFather').innerText=s.father||'';document.getElementById('showContact').innerText=s.contact||'';document.getElementById('showAddress').innerText=s.address||'';if(s.photoImage)document.getElementById('photoPreview').src=s.photoImage;applyStudentGlobal();if(s.positions){document.querySelectorAll('#studentCard .draggable').forEach(el=>{const idAttr=el.getAttribute('data-id');if(idAttr&&s.positions[idAttr]){el.style.left=s.positions[idAttr].left;el.style.top=s.positions[idAttr].top;}});}}
function resetStudentPos(){if(studentLocked){alert('Unlock first');return;}document.querySelectorAll('#studentCard .draggable').forEach(el=>{const l=el.getAttribute('data-original-left');const t=el.getAttribute('data-original-top');if(l&&t){el.style.left=l+'px';el.style.top=t+'px';}});saveStudentPositions();}
function toggleStudentLock(){studentLocked=!studentLocked;document.getElementById('lockBtn').innerText=studentLocked?'🔒 Locked':'🔓 Unlock';}
function downloadStudentCard(){html2canvas(document.getElementById('studentCard'),{scale:3,backgroundColor:'#ffffff'}).then(c=>c.toBlob(b=>{const a=document.createElement('a');a.href=URL.createObjectURL(b);a.download=(document.getElementById('showName').innerText||'student')+'_ID_Card.png';a.click();}));}
let studentDrag=null,sOffX=0,sOffY=0;
function sStart(e){if(studentLocked||!document.getElementById('studentCard'))return;studentDrag=e.currentTarget;const r=studentDrag.getBoundingClientRect(),cr=document.getElementById('studentCard').getBoundingClientRect();sOffX=e.clientX-r.left;sOffY=e.clientY-r.top;studentDrag.classList.add('dragging');e.preventDefault();}
function sMove(e){if(!studentDrag)return;const cr=document.getElementById('studentCard').getBoundingClientRect(),er=studentDrag.getBoundingClientRect();let l=e.clientX-cr.left-sOffX,t=e.clientY-cr.top-sOffY;l=Math.min(Math.max(l,0),cr.width-er.width);t=Math.min(Math.max(t,0),cr.height-er.height);studentDrag.style.left=l+'px';studentDrag.style.top=t+'px';}
function sEnd(){if(studentDrag){studentDrag.classList.remove('dragging');saveStudentPositions();studentDrag=null;}}
function saveStudentPositions(){if(!currentStudentId)return;const s=students.find(s=>s.id===currentStudentId);if(s){const pos={};document.querySelectorAll('#studentCard .draggable').forEach(el=>{const idAttr=el.getAttribute('data-id');if(idAttr)pos[idAttr]={left:el.style.left,top:el.style.top};});s.positions=pos;updateStudentInFB(s);}}

