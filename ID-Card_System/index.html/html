// --- DRAG FIX: attach mousedown listeners to draggable elements ---
function attachStudentDragEvents() {
  const card = document.getElementById('studentCard');
  if(!card) return;
  const draggables = card.querySelectorAll('.draggable');
  draggables.forEach(el => {
    // remove old to avoid duplicates
    el.removeEventListener('mousedown', sStart);
    el.addEventListener('mousedown', sStart);
  });
}
function attachTeacherDragEvents() {
  const card = document.getElementById('teacherCard');
  if(!card) return;
  const draggables = card.querySelectorAll('.draggable');
  draggables.forEach(el => {
    el.removeEventListener('mousedown', tStart);
    el.addEventListener('mousedown', tStart);
  });
}
