async function preloadData() {
    showLoading(true);
    try {
        await loadDataFromFirebase();
    } catch(e) {
        console.error(e);
        alert('Failed to load initial data. Please refresh.');
    } finally {
        showLoading(false);
        document.getElementById('loginBtn').disabled = false;
    }
}

function doLogin(){
  const role=document.getElementById('loginRole').value;
  const mobileOrUser=document.getElementById('loginMobile').value.trim();
  const dobOrPass=document.getElementById('loginDob').value.trim();
  const err=document.getElementById('loginError'); err.innerText='';
  if(role==='student'){
    const inputDob=normalizeDateToYMD(dobOrPass);
    const s=students.find(s=>normalizeDateToYMD(s.dob)===inputDob && s.mobile===mobileOrUser);
    if(s){ currentUser={role:'student',id:s.id,name:s.name}; showApp(); }
    else err.innerText='Invalid mobile or DOB';
  }else if(role==='teacher'){
    let inputDob=dobOrPass;
    if(inputDob.includes('/')) inputDob=normalizeDateToYMD(inputDob);
    const t=teachers.find(t=>normalizeDateToYMD(t.dob)===inputDob && t.mobile===mobileOrUser);
    if(t){ currentUser={role:'teacher',id:t.id,name:t.name}; showApp(); }
    else err.innerText='Invalid teacher credentials';
  }else if(role==='admin'){
    if(mobileOrUser==='admin' && dobOrPass===adminPassword){ currentUser={role:'admin',name:'Admin'}; showApp(); }
    else err.innerText='Invalid admin credentials';
  }
}

async function showApp(){
  document.getElementById('loginContainer').style.display='none';
  document.getElementById('mainApp').style.display='block';
  document.getElementById('backupPanel').style.display = 'none';
  document.getElementById('adminStatsRow').style.display = 'none';
  document.getElementById('modeToggle').innerHTML = '';
  document.getElementById('mainContainer').innerHTML = '<p style="text-align:center; padding:40px;">⏳ Loading…</p>';
  await loadDataFromFirebase();
  updateTopBarTitle();
  initRoleUI();
}

function logout(){ currentUser=null; document.getElementById('mainApp').style.display='none'; document.getElementById('loginContainer').style.display='flex'; document.getElementById('loginMobile').value=''; document.getElementById('loginDob').value=''; }
function updateTopBarTitle(){
  const titleEl=document.getElementById('topBarTitle');
  if(!titleEl||!currentUser)return;
  let photoUrl='';
  if(currentUser.role==='teacher'){ const t=teachers.find(t=>t.id===currentUser.id); photoUrl=t?t.photo||'':''; titleEl.innerHTML=`<img src="${escapeHtml(photoUrl)}" onerror="this.style.display='none'" style="width:40px;height:40px;border-radius:50%;object-fit:cover;border:2px solid #001B4E;"> 👩‍🏫 Welcome, ${escapeHtml(currentUser.name)}`; }
