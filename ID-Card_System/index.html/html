// --- Backup ---
function exportAllData(){const backup={students,teachers};const blob=new Blob([JSON.stringify(backup,null,2)],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='id_card_backup.json';a.click();}
async function importBackup(file){const reader=new FileReader();reader.onload=async function(e){try{const data=JSON.parse(e.target.result);if(!data.students||!data.teachers)throw new Error('Invalid structure');showLoading(true);await Promise.all(students.map(s=>deleteStudentFromFB(s.id)));await Promise.all(teachers.map(t=>deleteTeacherFromFB(t.id)));students=[];teachers=[];for(const s of data.students){const added=await addStudentToFB(s);students.push(added);}for(const t of data.teachers){const added=await addTeacherToFB(t);teachers.push(added);}students.forEach(s => s._printSelected = false);alert('Backup imported!');if(currentUser?.role==='admin'){updateAdminStats();if(currentAdminMode==='student'){renderStudentList();if(students.length){currentStudentId=students[0].id;loadStudentToCard(currentStudentId);}else clearStudentCard();}else{renderTeacherList();if(teachers.length){currentTeacherCardId=teachers[0].id;loadTeacherToCard(currentTeacherCardId);}else clearTeacherCard();}}else if(currentUser?.role==='teacher'){filterTStudList();}else if(currentUser?.role==='student'){location.reload();}}catch(err){alert('Error reading backup: '+err.message);}finally{showLoading(false);}};reader.readAsText(file);}

