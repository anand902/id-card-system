// ---------- PRINT PORTAL (Aadhaar card size 85.6×54 mm) ----------
function openPrintPortal(){
  document.getElementById('printPortalModal').style.display='flex';
  const classFilter = document.getElementById('printClassFilter');
  classFilter.innerHTML = getClassFilterOptions();
  document.getElementById('printBgUpload').value = '';
  document.getElementById('printSigUpload').value = '';
  renderPrintStudentList();
  const anySelected = students.some(s => s._printSelected);
  if(anySelected) generatePrintSheet();
  else document.getElementById('printSheetContainer').innerHTML = '<p style="color:#888;">Select students and click "Generate Preview" to see print sheets.</p>';
}
function closePrintPortal(){ document.getElementById('printPortalModal').style.display='none'; }
function renderPrintStudentList(){
  const container = document.getElementById('printStudentList');
  const selectedClass = document.getElementById('printClassFilter').value;
  let filtered = students;
  if(selectedClass) filtered = students.filter(s => s.class === selectedClass);
  if(!filtered.length){ container.innerHTML = '<div style="padding:15px;">No students.</div>'; return; }
  container.innerHTML = filtered.map(s => `
    <div class="list-item">
      <label style="display:flex; align-items:center; gap:10px; cursor:pointer;">
        <input type="checkbox" class="print-check" value="${escapeHtml(s.id)}" ${s._printSelected ? 'checked' : ''}>
        <span>${escapeHtml(s.name)} (${escapeHtml(s.class||'')})</span>
      </label>
    </div>`).join('');
  container.querySelectorAll('.print-check').forEach(cb => {
    const s = students.find(s => s.id === cb.value);
    if(s) s._printSelected = cb.checked;
    cb.addEventListener('change', function(){
      const st = students.find(s => s.id === this.value);
      if(st) st._printSelected = this.checked;
    });
  });
}
document.getElementById('printClassFilter')?.addEventListener('change', renderPrintStudentList);
document.getElementById('selectAllPrint')?.addEventListener('click', ()=>{
  document.querySelectorAll('.print-check').forEach(cb => { cb.checked = true; const s=students.find(s=>s.id===cb.value); if(s) s._printSelected=true; });
});
document.getElementById('deselectAllPrint')?.addEventListener('click', ()=>{
  document.querySelectorAll('.print-check').forEach(cb => { cb.checked = false; const s=students.find(s=>s.id===cb.value); if(s) s._printSelected=false; });
});

