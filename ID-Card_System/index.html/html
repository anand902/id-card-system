async function generatePrintSheet() {
  const selectedIds = students.filter(s => s._printSelected).map(s => s.id);
  const container = document.getElementById('printSheetContainer');
  if(selectedIds.length === 0){ container.innerHTML = '<p style="color:#888;">Please select at least one student.</p>'; return; }
  showLoading(true);
  container.innerHTML = '<p>⏳ Generating print sheets...</p>';
  try {
    const bgFile = document.getElementById('printBgUpload').files[0];
    const sigFile = document.getElementById('printSigUpload').files[0];
    let printBg = globalBgImage;
    let printSig = globalSignatureImage;
    if(bgFile){ try { printBg = await fileToBase64(bgFile, 2000); } catch(e){ alert('Background too large'); showLoading(false); return; } }
    if(sigFile){ try { printSig = await fileToBase64(sigFile, 2000); } catch(e){ alert('Signature too large'); showLoading(false); return; } }

    const hiddenDiv = document.createElement('div');
    hiddenDiv.style.position = 'absolute'; hiddenDiv.style.left = '-9999px'; hiddenDiv.style.top = '0';
    document.body.appendChild(hiddenDiv);

    const cardsPerSheet = 10;
    const sheets = [];
    const cardWidthMM = 85.6, cardHeightMM = 54;   // Aadhaar size
    const dpi = 300;
    const a4Width = 210, a4Height = 297;
    const mmToPx = dpi / 25.4;
    const sheetCanvasWidth = Math.round(a4Width * mmToPx);
    const sheetCanvasHeight = Math.round(a4Height * mmToPx);
    const cardWidthPx = Math.round(cardWidthMM * mmToPx);
    const cardHeightPx = Math.round(cardHeightMM * mmToPx);
    const cols = 2, rows = 5;
    const marginX = Math.round((a4Width - cols * cardWidthMM) / (cols + 1) * mmToPx);
    const marginY = Math.round((a4Height - rows * cardHeightMM) / (rows + 1) * mmToPx);

    for(let i=0; i<selectedIds.length; i+=cardsPerSheet){
      const batch = selectedIds.slice(i, i+cardsPerSheet);
      const sheetCanvas = document.createElement('canvas');
      sheetCanvas.width = sheetCanvasWidth;
      sheetCanvas.height = sheetCanvasHeight;
      const ctx = sheetCanvas.getContext('2d');
      ctx.fillStyle = '#ffffff';
      ctx.fillRect(0, 0, sheetCanvas.width, sheetCanvas.height);

      for(let j=0; j<batch.length; j++){
        const studentId = batch[j];
        const row = Math.floor(j / cols);
        const col = j % cols;
        const x = marginX + col * (cardWidthPx + marginX);
        const y = marginY + row * (cardHeightPx + marginY);

        const tempCard = document.createElement('div');
        tempCard.style.width = '260px'; tempCard.style.height = '410px'; tempCard.style.position = 'relative';
        tempCard.innerHTML = generateCardHTML(studentId, printBg, printSig);
        hiddenDiv.appendChild(tempCard);
        const s = students.find(s=>s.id===studentId);
        if(s && s.positions){
          tempCard.querySelectorAll('.draggable').forEach(el => {
            const idAttr = el.getAttribute('data-id');
            if(idAttr && s.positions[idAttr]){
              el.style.left = s.positions[idAttr].left;
              el.style.top = s.positions[idAttr].top;
            }
          });
        }
        const cardCanvas = await html2canvas(tempCard, { scale: 1, backgroundColor: '#ffffff' });
        hiddenDiv.removeChild(tempCard);
        ctx.save();
        ctx.translate(x + cardWidthPx/2, y + cardHeightPx/2);
        ctx.rotate(-90 * Math.PI/180);
        ctx.drawImage(cardCanvas, -cardHeightPx/2, -cardWidthPx/2, cardHeightPx, cardWidthPx);
        ctx.restore();
      }
      sheets.push(sheetCanvas.toDataURL('image/png'));
    }
    document.body.removeChild(hiddenDiv);

    container.innerHTML = sheets.map((dataUrl, idx) => `
      <div class="print-sheet" style="width:210mm; height:297mm; background:white; margin-bottom:20px; position:relative;">
        <img src="${dataUrl}" style="width:100%; height:100%;" alt="Print Sheet ${idx+1}">
        <button class="download-sheet-btn" data-url="${dataUrl}" data-index="${idx+1}" style="position:absolute; bottom:10px; right:10px; background:#28a745; color:#fff; border:none; border-radius:6px; padding:6px 12px; cursor:pointer; font-size:11px;">💾 Download Sheet ${idx+1}</button>
      </div>
    `).join('');
    container.querySelectorAll('.download-sheet-btn').forEach(btn => {
      btn.addEventListener('click', function(e){
        e.stopPropagation();
        const url = this.getAttribute('data-url');
        const idx = this.getAttribute('data-index');
        const a = document.createElement('a');
        a.href = url;
        a.download = `ID_Cards_Sheet_${idx}.png`;
        a.click();
      });
    });
    container.innerHTML += `<p style="margin-top:10px; color:#555;">✅ ${sheets.length} sheet(s) generated. ${selectedIds.length} card(s) total. Each card 85.6×54 mm (Aadhaar size).</p>`;
  } catch(err) { console.error(err); container.innerHTML = '<p style="color:red;">❌ Error generating print sheets.</p>'; }
  finally { showLoading(false); }
}

function downloadPrintSheets() {
  const sheets = document.querySelectorAll('.print-sheet');
  if(sheets.length === 0){ alert('No print sheets generated. Click "Generate Preview" first.'); return; }
  window.print();
}

